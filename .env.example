# OpenCode Database Path
# Find with: find ~ -name "opencode.db" 2>/dev/null
OPENCEDE_DB_PATH=/home/youruser/.local/share/opencode/opencode.db

# Obsidian Vault Path
# Where notes will be exported
OBSIDIAN_VAULT_PATH=/path/to/your/vault

# Optional: Date Range (defaults to last 30 days)
# START_DATE=2026-04-01
# END_DATE=2026-05-07

# Optional: Number of days to look back (default: 30)
# DAYS=30

# Optional: Performance Reflection Template Path
# If you want weekly performance reflections, set the path to your template
# Defaults to: {OBSIDIAN_VAULT_PATH}/Templates/Weekly Performance Reflection.md
# PERFORMANCE_TEMPLATE_PATH=/path/to/your/Templates/Weekly Performance Reflection.md
